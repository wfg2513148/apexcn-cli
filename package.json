{
  "name": "apexcn-cli",
  "version": "0.80.4",
  "type": "module",
  "bin": {
    "apexcn": "./dist/index.js"
  },
  "files": [
    "agent-skill/",
    "dist/",
    "docs/",
    "eval/rag/",
    "eval/collection/",
    "eval/retrieval/",
    "issues.json",
    "roadmap.json",
    "scripts/e2e-readonly.sh",
    "scripts/baseline-report.mjs",
    "scripts/eval-rag.mjs",
    "scripts/eval-collection.mjs",
    "scripts/eval-retrieval.mjs",
    "scripts/retrieval-eval-score.mjs",
    "scripts/generate-release-checksums.mjs",
    "scripts/install-agent.ps1",
    "scripts/install-agent.sh",
    "scripts/lifecycle-agent.ps1",
    "scripts/lifecycle-agent.sh",
    "scripts/soak-readonly.mjs",
    "README.md"
  ],
  "scripts": {
    "baseline": "node scripts/baseline-report.mjs",
    "build": "tsc -p tsconfig.json",
    "check:release": "node scripts/check-release-version.mjs && node scripts/check-release-artifacts.mjs && node scripts/check-workflows.mjs && node scripts/check-source-layout.mjs && node scripts/check-roadmap.mjs",
    "check:roadmap": "node scripts/check-roadmap.mjs",
    "check:source-layout": "node scripts/check-source-layout.mjs",
    "check:workflows": "node scripts/check-workflows.mjs",
    "context:compact": "node scripts/compact-iteration-context.mjs",
    "eval:rag": "node scripts/eval-rag.mjs --report",
    "eval:collection": "node scripts/eval-collection.mjs --report",
    "eval:retrieval": "node scripts/eval-retrieval.mjs --report",
    "qualify:mcp": "node scripts/qualify-mcp.mjs",
    "roadmap:render": "node scripts/check-roadmap.mjs --write-docs",
    "soak:readonly": "node scripts/soak-readonly.mjs",
    "test": "vitest run",
    "test:e2e:readonly": "bash scripts/e2e-readonly.sh"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "bundledDependencies": [
    "commander"
  ],
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "bundleDependencies": [
    "commander"
  ]
}
