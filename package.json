{
  "name": "apexcn-cli",
  "version": "0.18.13",
  "type": "module",
  "bin": {
    "apexcn": "./dist/index.js"
  },
  "files": [
    "agent-skill/",
    "dist/",
    "docs/",
    "eval/rag/",
    "scripts/e2e-readonly.sh",
    "scripts/baseline-report.mjs",
    "scripts/eval-rag.mjs",
    "scripts/generate-release-checksums.mjs",
    "scripts/install-agent.ps1",
    "scripts/install-agent.sh",
    "README.md"
  ],
  "scripts": {
    "baseline": "node scripts/baseline-report.mjs",
    "build": "tsc -p tsconfig.json",
    "check:release": "node scripts/check-release-version.mjs && node scripts/check-release-artifacts.mjs && node scripts/check-workflows.mjs && node scripts/check-source-layout.mjs",
    "check:source-layout": "node scripts/check-source-layout.mjs",
    "check:workflows": "node scripts/check-workflows.mjs",
    "eval:rag": "node scripts/eval-rag.mjs --report",
    "test": "vitest run",
    "test:e2e:readonly": "bash scripts/e2e-readonly.sh"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "bundledDependencies": [
    "commander"
  ],
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
